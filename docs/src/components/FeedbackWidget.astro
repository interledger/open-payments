---
const { lang = 'en' } = Astro.props

const translations = {
  en: {
    question: 'Was this page helpful?',
    yes: 'Yes',
    no: 'No',
    thanks: 'Thanks for your feedback!',
    improve: 'Help us improve',
    improvePlaceholder: 'What can we improve?',
    submit: 'Submit',
    submitting: 'Submitting...',
    submitError:
      'Could not submit feedback. Check your connection and try again.'
  },
  es: {
    question: '¿Fue útil esta página?',
    yes: 'Sí',
    no: 'No',
    thanks: '¡Gracias por tu comentario!',
    improve: 'Ayúdanos a mejorar',
    improvePlaceholder: '¿Qué podemos mejorar?',
    submit: 'Enviar',
    submitting: 'Enviando...',
    submitError:
      'No se pudo enviar el comentario. Comprueba tu conexión e inténtalo de nuevo.'
  }
}

const t = translations[lang as keyof typeof translations] || translations.en
const functionUrl =
  typeof import.meta.env.PUBLIC_FEEDBACK_FUNCTION_URL === 'string'
    ? import.meta.env.PUBLIC_FEEDBACK_FUNCTION_URL.trim()
    : ''
---

<div
  class="feedback-widget"
  id="feedback-widget"
  data-function-url={functionUrl}
  data-issue-repo="interledger/open-payments-docs-feedback"
  data-submit-error={t.submitError}
>
  <div class="feedback-question">
    <h3>{t.question}</h3>
    <div class="feedback-buttons">
      <button
        class="feedback-btn feedback-yes"
        data-feedback="yes"
        type="button"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 20 20"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M10 1.5L12.5 6.5L18 7.5L14 11.5L15 17L10 14.5L5 17L6 11.5L2 7.5L7.5 6.5L10 1.5Z"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        {t.yes}
      </button>
      <button class="feedback-btn feedback-no" data-feedback="no" type="button">
        <svg
          width="20"
          height="20"
          viewBox="0 0 20 20"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M15 5L5 15M5 5L15 15"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"></path>
        </svg>
        {t.no}
      </button>
    </div>
  </div>

  <div class="feedback-form hidden" id="feedback-form">
    <p class="feedback-thanks">{t.thanks}</p>
    <label for="feedback-text">{t.improve}</label>
    <textarea id="feedback-text" rows="4" placeholder={t.improvePlaceholder}
    ></textarea>
    <button
      class="feedback-submit"
      id="submit-feedback"
      data-submitting={t.submitting}
      type="button"
    >
      {t.submit}
    </button>
  </div>

  <div class="feedback-success hidden" id="feedback-success" aria-live="polite">
    <p>{t.thanks}</p>
  </div>
  <div class="feedback-error hidden" id="feedback-error" role="alert"></div>
</div>

<style>
  .feedback-widget {
    margin-top: var(--sl-spacing-2xl, 2rem);
    padding: var(--sl-spacing-m, 1rem);
    border-top: 1px solid var(--sl-color-hairline-shade, #e0e0e0);
  }

  .feedback-question h3 {
    font-size: var(--sl-text-base, 1rem);
    font-weight: 600;
    margin: 0 0 var(--sl-spacing-s, 0.75rem) 0;
    color: var(--sl-color-text, #333);
  }

  .feedback-buttons {
    display: flex;
    gap: var(--sl-spacing-xs, 0.5rem);
  }

  .feedback-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border: 1px solid var(--sl-color-hairline-shade, #e0e0e0);
    background: var(--sl-color-bg, white);
    color: var(--sl-color-text, #333);
    border-radius: 0.375rem;
    cursor: pointer;
    font-size: 0.875rem;
    transition:
      background-color 0.2s,
      border-color 0.2s,
      color 0.2s;
  }

  .feedback-btn:hover {
    background: var(--sl-color-bg-nav, #f5f5f5);
    border-color: var(--sl-color-text-accent, #0066cc);
  }

  .feedback-btn svg {
    flex-shrink: 0;
  }

  .feedback-yes:hover {
    color: #16a34a;
    border-color: #16a34a;
  }

  .feedback-no:hover {
    color: #dc2626;
    border-color: #dc2626;
  }

  .feedback-form {
    margin-top: var(--sl-spacing-m, 1rem);
  }

  .feedback-form label {
    display: block;
    margin-bottom: var(--sl-spacing-2xs, 0.25rem);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--sl-color-text, #333);
  }

  .feedback-form textarea {
    width: 100%;
    padding: 0.5rem;
    border: 1px solid var(--sl-color-hairline-shade, #e0e0e0);
    border-radius: 0.375rem;
    font-family: inherit;
    font-size: 0.875rem;
    resize: vertical;
    background: var(--sl-color-bg, white);
    color: var(--sl-color-text, #333);
  }

  .feedback-form textarea:focus {
    outline: none;
    border-color: var(--sl-color-text-accent, #0066cc);
    box-shadow: 0 0 0 3px rgba(0, 102, 204, 0.1);
  }

  .feedback-submit {
    margin-top: var(--sl-spacing-xs, 0.5rem);
    padding: 0.5rem 1rem;
    background: var(--sl-color-text-accent, #0066cc);
    color: white;
    border: none;
    border-radius: 0.375rem;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    transition: background-color 0.2s;
  }

  .feedback-submit:hover {
    background: var(--sl-color-text-accent-high, #0052a3);
  }

  .feedback-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .feedback-thanks {
    color: #16a34a;
    font-weight: 500;
    margin-bottom: var(--sl-spacing-xs, 0.5rem);
  }

  .feedback-success {
    color: #16a34a;
    font-weight: 500;
    padding: var(--sl-spacing-m, 1rem);
    text-align: center;
  }

  .feedback-error {
    margin-top: var(--sl-spacing-m, 1rem);
    padding: var(--sl-spacing-s, 0.75rem);
    border-radius: 0.375rem;
    background: #fef2f2;
    color: #b91c1c;
    font-size: 0.875rem;
  }

  .hidden {
    display: none;
  }
</style>

<script>
  type FeedbackChoice = 'yes' | 'no'
  type TrackPayload = Record<string, string | number | boolean>

  const widget = document.getElementById('feedback-widget')

  const track = (eventName: string, payload: TrackPayload) => {
    const analytics = (
      window as Window & {
        umami?: {
          track: (
            trackedEventName: string,
            trackedPayload?: TrackPayload
          ) => void
        }
      }
    ).umami

    analytics?.track(eventName, payload)
  }

  if (widget instanceof HTMLElement) {
    const feedbackQuestion =
      widget.querySelector<HTMLElement>('.feedback-question')
    const feedbackButtons = Array.from(
      widget.querySelectorAll<HTMLButtonElement>('.feedback-btn')
    )
    const feedbackForm = widget.querySelector<HTMLElement>('#feedback-form')
    const feedbackSuccess =
      widget.querySelector<HTMLElement>('#feedback-success')
    const feedbackText =
      widget.querySelector<HTMLTextAreaElement>('#feedback-text')
    const submitButton =
      widget.querySelector<HTMLButtonElement>('#submit-feedback')
    const functionUrl = widget.dataset.functionUrl?.trim() || ''
    const issueRepo =
      widget.dataset.issueRepo || 'interledger/open-payments-docs-feedback'
    const submitErrorDefault =
      widget.dataset.submitError ||
      'Could not submit feedback. Check your connection and try again.'
    const feedbackError =
      widget.querySelector<HTMLElement>('#feedback-error')

    let selectedFeedback: FeedbackChoice | null = null

    const hideError = () => {
      feedbackError?.classList.add('hidden')
      if (feedbackError) {
        feedbackError.textContent = ''
      }
    }

    const showError = (message: string) => {
      if (!feedbackError) {
        return
      }
      feedbackError.textContent = message
      feedbackError.classList.remove('hidden')
    }

    const showSuccess = () => {
      hideError()
      feedbackForm?.classList.add('hidden')
      feedbackSuccess?.classList.remove('hidden')
    }

    const createIssueUrl = (
      feedbackType: FeedbackChoice,
      page: string,
      message: string
    ) => {
      const emoji = feedbackType === 'yes' ? '👍' : '👎'
      const sentiment = feedbackType === 'yes' ? 'Positive' : 'Negative'
      const issueUrl = new URL(`https://github.com/${issueRepo}/issues/new`)

      issueUrl.searchParams.set('title', `[Feedback] ${emoji} ${page}`)
      issueUrl.searchParams.set(
        'body',
        `**Page:** ${page}
**Feedback Type:** ${sentiment} ${emoji}
**User Message:**

${message || '_No additional feedback provided_'}`
      )
      issueUrl.searchParams.set('labels', 'feedback,docs')

      return issueUrl.toString()
    }

    const openIssueFallback = (
      feedbackType: FeedbackChoice,
      page: string,
      message: string
    ) => {
      const issueUrl = createIssueUrl(feedbackType, page, message)
      const openedWindow = window.open(issueUrl, '_blank', 'noopener')

      if (!openedWindow) {
        window.location.href = issueUrl
        return
      }

      showSuccess()
      track('feedback', {
        type: feedbackType,
        hasMessage: message.length > 0,
        delivery: 'github-issue'
      })
    }

    feedbackButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const choice = button.dataset.feedback

        if (choice !== 'yes' && choice !== 'no') {
          return
        }

        selectedFeedback = choice
        hideError()
        feedbackQuestion?.classList.add('hidden')
        feedbackForm?.classList.remove('hidden')
        feedbackText?.focus()
      })
    })

    if (submitButton instanceof HTMLButtonElement) {
      submitButton.addEventListener('click', async () => {
        if (!selectedFeedback) {
          return
        }

        const feedback = feedbackText?.value.trim() || ''
        const page = window.location.pathname
        const originalLabel = submitButton.textContent

        submitButton.disabled = true
        submitButton.textContent =
          submitButton.dataset.submitting || 'Submitting...'

        try {
          if (!functionUrl) {
            openIssueFallback(selectedFeedback, page, feedback)
            return
          }

          hideError()
          const controller = new AbortController()
          const timeoutId = window.setTimeout(() => controller.abort(), 25_000)

          const response = await fetch(functionUrl, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              type: selectedFeedback,
              page,
              message: feedback
            }),
            signal: controller.signal
          })

          const rawResponse = await response.text()
          window.clearTimeout(timeoutId)

          let result: { success?: boolean; error?: string } = {}

          if (rawResponse) {
            try {
              result = JSON.parse(rawResponse) as {
                success?: boolean
                error?: string
              }
            } catch {
              result = {}
            }
          }

          if (!response.ok || !result.success) {
            showError(result.error || submitErrorDefault)
            track('feedback', {
              type: selectedFeedback,
              hasMessage: feedback.length > 0,
              delivery: 'function-error',
              status: response.status
            })
            return
          }

          showSuccess()
          track('feedback', {
            type: selectedFeedback,
            hasMessage: feedback.length > 0,
            delivery: 'function'
          })
        } catch {
          showError(submitErrorDefault)
          track('feedback', {
            type: selectedFeedback!,
            hasMessage: feedback.length > 0,
            delivery: 'function-error'
          })
        } finally {
          submitButton.disabled = false
          submitButton.textContent = originalLabel
        }
      })
    }
  }
</script>
