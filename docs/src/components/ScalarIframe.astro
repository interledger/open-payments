---
/**
 * Embeds an isolated Scalar API reference page inside a Starlight layout.
 *
 * Scalar is embedded via <iframe> rather than inline because @scalar/astro's
 * ScalarComponent injects a full HTML document inline, causing Scalar's global
 * CSS to bleed into the surrounding Starlight page. The iframe provides proper
 * CSS isolation so Scalar cannot affect the parent layout.
 *
 * The frame source pages live at /apis/scalar/frames/[spec] and are defined in
 * src/pages/apis/scalar/frames/[spec].astro.
 */
interface Props {
  /** URL of the frame page to embed (e.g. /apis/scalar/frames/auth-server) */
  src: string
  /** Accessible title for the iframe */
  title: string
  /** When true, adds the .scalar-wide class for the full-width splash layout */
  wide?: boolean
  /** When true, hides the feedback widget and footer nav for maximum content space */
  noFooter?: boolean
}

const { src, title, wide = false, noFooter = false } = Astro.props
---

<div
  class:list={[
    'scalar-embed',
    'not-content',
    { 'scalar-wide': wide, 'scalar-minimal': noFooter }
  ]}
>
  <iframe class="scalar-frame" src={src} title={title}></iframe>
</div>

<script>
  const iframe = document.querySelector<HTMLIFrameElement>('.scalar-frame')

  /**
   * Sync Starlight's current theme to Scalar. Parent and frame share localStorage
   * (same origin), so writing colorMode there and reloading the frame is enough —
   * Scalar reads it on init. Guard with an equality check to avoid reload loops.
   */
  function syncTheme() {
    if (!iframe) return
    const colorMode =
      document.documentElement.dataset.theme === 'light' ? 'light' : 'dark'
    if (localStorage.getItem('colorMode') === colorMode) return
    localStorage.setItem('colorMode', colorMode)
    iframe.style.transition = 'opacity 0.2s'
    iframe.style.opacity = '0'
    iframe.addEventListener(
      'load',
      () => {
        iframe.style.opacity = '1'
      },
      { once: true }
    )
    iframe.setAttribute('src', iframe.src) // trigger reload in new theme
  }

  iframe?.addEventListener('load', syncTheme)
  new MutationObserver(syncTheme).observe(document.documentElement, {
    attributeFilter: ['data-theme']
  })

  // Pre-set the plugin's sessionStorage key before DOMContentLoaded fires so the
  // plugin collapses the sidebar natively on minimal pages. On unload, restore the
  // previous value so other pages (including non-scalar ones) aren't affected.
  if (document.querySelector('.scalar-minimal')) {
    const wasAlreadyCollapsed =
      sessionStorage.getItem('mainSideBarCollapsed') === 'true'
    if (!wasAlreadyCollapsed) {
      sessionStorage.setItem('mainSideBarCollapsed', 'true')
      sessionStorage.setItem('scalarMinimalForced', 'true')
    }
    window.addEventListener('beforeunload', () => {
      if (sessionStorage.getItem('scalarMinimalForced') === 'true') {
        sessionStorage.removeItem('scalarMinimalForced')
        if (sessionStorage.getItem('mainSideBarCollapsed') === 'true') {
          sessionStorage.setItem('mainSideBarCollapsed', 'false')
        }
      }
    })
  }
</script>

<style is:global>
  /* Prevent the ILF design system's div+div spacing rule from affecting the iframe */
  body:has(.scalar-embed) .scalar-embed {
    --space-m: 0;
    --space-s: 0;
  }

  /* Remove ILF decorative underlines from headings inside Scalar pages */
  body:has(.scalar-embed) .sl-container h1:first-of-type::after,
  body:has(.scalar-embed) .sl-container h3::after {
    content: none;
  }

  /* On full-width (splash) pages, hide the first ContentPanel which only contains the page title */
  body:has(.scalar-wide) main > .content-panel:first-of-type {
    display: none;
  }

  /* Hide edit/last-updated meta on scalar pages — not meaningful for API reference */
  body:has(.scalar-embed) footer.sl-flex .meta {
    display: none;
  }

  /* On minimal pages, hide the feedback widget and footer entirely for maximum content space */
  body:has(.scalar-minimal) .feedback-widget,
  body:has(.scalar-minimal) footer.sl-flex {
    display: none;
  }

  /* On minimal pages, pull the toggle button out of the collapsed sidebar's
   * overflow:hidden container by fixing it to the viewport. position:fixed children
   * are not clipped by ancestor overflow, so the button is always visible. */
  body.main-side-bar-collapsed:has(.scalar-minimal) .toggle-left-side-bar-btn {
    position: fixed;
    left: 0;
    top: calc(var(--sl-nav-height) + 1rem);
    width: 1.5rem;
    height: 3rem;
    background: var(--sl-color-bg-sidebar);
    border: 1px solid var(--sl-color-hairline-shade);
    border-left: none;
    border-radius: 0 0.5rem 0.5rem 0;
    z-index: calc(var(--sl-z-index-menu) + 1);
    display: flex !important;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  /* Prevent ghost-clicks through the opacity-0 nav items when the sidebar is collapsed */
  body.main-side-bar-collapsed:has(.scalar-minimal) ul.top-level {
    pointer-events: none;
  }

  /*
   * Flex chain: make the page fill exactly the viewport with no outer scroll.
   * main becomes a flex column; .sl-markdown-content gets flex:1 and pushes
   * the feedback widget + footer to the bottom naturally.
   */
  html:has(.scalar-embed) {
    height: 100%;
    overflow: hidden;
  }

  html:has(.scalar-embed) body {
    height: 100%;
  }

  html:has(.scalar-embed) main {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    height: calc(100vh - var(--sl-nav-height));
    overflow: hidden;
  }

  html:has(.scalar-embed) main > .content-panel:last-of-type {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding-bottom: 0;
  }

  html:has(.scalar-embed) main > .content-panel:last-of-type > .sl-container {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }

  html:has(.scalar-embed)
    main
    > .content-panel:last-of-type
    .sl-markdown-content {
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  body:has(.scalar-embed) .scalar-embed {
    height: 100%;
  }

  .scalar-frame {
    width: 100%;
    border: none;
    display: block;
    height: 100%;
  }
</style>
